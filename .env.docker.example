# ============================================
# Variables para Docker — Sistema Dental
# ============================================
# Copiá este archivo a .env y completá los valores.
#
# BUILD TIME (requieren rebuild: docker compose build)
# Se inlined en el bundle del cliente (NEXT_PUBLIC_*)
# ============================================
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key"
NEXT_PUBLIC_APP_URL="http://localhost:3010"

# ============================================
# RUNTIME (solo restart: docker compose up -d)
# Secretos del servidor, no requieren rebuild
# ============================================
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"
GROQ_API_KEY="tu-groq-api-key"
ADMIN_EMAIL="admin@ejemplo.com"
ADMIN_PASSWORD="tu-password-seguro"

# ============================================
# Docker (opcional)
# ============================================
APP_PORT=3010
# Opcional — solo si usás docker-compose.coffeemap.yml
# DOCKER_NETWORK=reverse_proxy_default
